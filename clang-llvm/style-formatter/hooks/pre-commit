#!/usr/bin/env bash
# =============================================================================
# pre-commit — LLVM C++ style enforcement hook
#
# Runs clang-format (style) and optionally clang-tidy (lint) against every
# staged C/C++ file.  The commit is REJECTED if any violations are found.
#
# Install:  run scripts/install-hooks.sh from the host repository root.
# Config:   hooks are driven by:
#             .clang-format     (lives in the submodule config/ directory)
#             .clang-tidy       (same)
#             .llvm-hooks/config/hooks.conf  (runtime toggles — see below)
#
# Requires: clang-format, clang-tidy (on PATH or discovered via find-tools.sh)
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# 0.  Locate the formatter submodule root regardless of where git runs from
# ---------------------------------------------------------------------------
REPO_ROOT="$(git rev-parse --show-toplevel)"
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# The submodule may live at .llvm-hooks/ or be invoked from .git/hooks/.
# Walk up to find the config directory.
SUBMODULE_ROOT=""
for candidate in \
    "${REPO_ROOT}/clang-llvm/style-formatter" \
    "${REPO_ROOT}/.llvm-hooks" \
    "${HOOK_DIR}/../.." \
    "${HOOK_DIR}/.."; do
    if [[ -f "${candidate}/config/hooks.conf" ]]; then
        SUBMODULE_ROOT="$(cd "${candidate}" && pwd)"
        break
    fi
done

if [[ -z "${SUBMODULE_ROOT}" ]]; then
    echo "[pre-commit] ERROR: Cannot locate clang-llvm-style-formatter config." >&2
    echo "             Expected a hooks.conf at <submodule>/config/hooks.conf"   >&2
    echo "             Run scripts/install-hooks.sh to set up the hook properly." >&2
    exit 1
fi

# Build --style=file: with a Windows-compatible path on MINGW/MSYS.
# clang-format on Windows requires C:\... paths not /c/... Unix paths.
_cf_config_path() {
    local p="${SUBMODULE_ROOT}/config/.clang-format"
    case "$(uname -s)" in
        MINGW*|MSYS*|CYGWIN*)
            cygpath -w "${p}" 2>/dev/null ||                 printf '%s' "${p}" | sed 's|/c/|C:\\|; s|/|\\|g' ;;
        *) printf '%s' "${p}" ;;
    esac
}
CF_STYLE_ARG="--style=file:$(_cf_config_path)"


CONF="${SUBMODULE_ROOT}/config/hooks.conf"
CONF_LOCAL="${SUBMODULE_ROOT}/.llvm-hooks-local/hooks.conf"

# ---------------------------------------------------------------------------
# 1.  Load configuration
#     Source the committed default first, then the per-repo local override
#     on top so developer customisations (ENABLE_TIDY, VERBOSE, binary path
#     overrides, etc.) actually take effect at commit time.
# ---------------------------------------------------------------------------
# shellcheck source=/dev/null
source "${CONF}"
# shellcheck source=/dev/null
[[ -f "${CONF_LOCAL}" ]] && source "${CONF_LOCAL}"

# Defaults if not set in hooks.conf
ENABLE_FORMAT="${ENABLE_FORMAT:-true}"
ENABLE_TIDY="${ENABLE_TIDY:-false}"
FORMAT_DIFF_ONLY="${FORMAT_DIFF_ONLY:-true}"
CLANG_FORMAT_BIN="${CLANG_FORMAT_BIN:-clang-format}"
CLANG_TIDY_BIN="${CLANG_TIDY_BIN:-clang-tidy}"
CPP_EXTENSIONS="${CPP_EXTENSIONS:-cpp,cxx,cc,c,h,hpp,hxx,hh}"
VERBOSE="${VERBOSE:-false}"

# ---------------------------------------------------------------------------
# 2.  Discover tools (honour explicit paths first, then PATH, then heuristics)
# ---------------------------------------------------------------------------
# shellcheck source=/dev/null
source "${SUBMODULE_ROOT}/scripts/find-tools.sh"

_check_tool() {
    local var="$1" bin="$2" label="$3"
    if ! command -v "${bin}" &>/dev/null; then
        echo "[pre-commit] ERROR: '${bin}' not found on PATH." >&2
        echo "             Run:  ${SUBMODULE_ROOT}/scripts/setup-user-path.sh" >&2
        echo "             then open a new shell and retry."                   >&2
        return 1
    fi
    printf "[pre-commit] Found %-14s → %s\n" "${label}" "$(command -v "${bin}")"
}

FORMAT_OK=true
TIDY_OK=true

if [[ "${ENABLE_FORMAT}" == "true" ]]; then
    _check_tool CLANG_FORMAT_BIN "${CLANG_FORMAT_BIN}" "clang-format" || FORMAT_OK=false
fi
if [[ "${ENABLE_TIDY}" == "true" ]]; then
    _check_tool CLANG_TIDY_BIN  "${CLANG_TIDY_BIN}"  "clang-tidy"   || TIDY_OK=false
fi

if [[ "${FORMAT_OK}" == "false" || "${TIDY_OK}" == "false" ]]; then
    exit 1
fi

# ---------------------------------------------------------------------------
# 3.  Collect staged C/C++ files
# ---------------------------------------------------------------------------
IFS=',' read -ra EXT_LIST <<< "${CPP_EXTENSIONS}"
EXT_PATTERN=""
for ext in "${EXT_LIST[@]}"; do
    EXT_PATTERN="${EXT_PATTERN}|\.${ext}"
done
EXT_PATTERN="${EXT_PATTERN:1}"   # strip leading |

mapfile -t STAGED_FILES < <(
    git diff --cached --name-only --diff-filter=ACMR |
    grep -E "(${EXT_PATTERN})$" || true
)

if [[ ${#STAGED_FILES[@]} -eq 0 ]]; then
    echo "[pre-commit] No C/C++ files staged — skipping style checks."
    exit 0
fi

echo "[pre-commit] Checking ${#STAGED_FILES[@]} staged file(s)…"
[[ "${VERBOSE}" == "true" ]] && printf '             %s\n' "${STAGED_FILES[@]}"

# ---------------------------------------------------------------------------
# 4.  clang-format check
# ---------------------------------------------------------------------------
FORMAT_FAILURES=()

if [[ "${ENABLE_FORMAT}" == "true" ]]; then
    for f in "${STAGED_FILES[@]}"; do
        abs="${REPO_ROOT}/${f}"
        [[ -f "${abs}" ]] || continue

        # Get the staged content (not the on-disk working tree content)
        staged_content="$(git show ":${f}")"

        # Run clang-format against the staged content via stdin
        formatted="$(echo "${staged_content}" | \
            "${CLANG_FORMAT_BIN}" \
                --style=file:"$(case "$(uname -s)" in MINGW*|MSYS*|CYGWIN*) cygpath -w "${SUBMODULE_ROOT}/config/.clang-format" 2>/dev/null || printf '%s' "${SUBMODULE_ROOT}/config/.clang-format" | sed 's|/c/|C:\\|; s|/|\\|g' ;; *) echo "${SUBMODULE_ROOT}/config/.clang-format" ;; esac)" \
                --assume-filename="${abs}" \
                2>/dev/null)"

        if [[ "${staged_content}" != "${formatted}" ]]; then
            FORMAT_FAILURES+=("${f}")
            if [[ "${VERBOSE}" == "true" ]]; then
                echo "--- formatted diff for: ${f} ---"
                diff <(echo "${staged_content}") <(echo "${formatted}") || true
            fi
        fi
    done
fi

# ---------------------------------------------------------------------------
# 5.  clang-tidy check  (optional, off by default — can be slow)
# ---------------------------------------------------------------------------
TIDY_FAILURES=()

if [[ "${ENABLE_TIDY}" == "true" ]]; then
    # clang-tidy needs a compile_commands.json; warn if absent
    if [[ ! -f "${REPO_ROOT}/compile_commands.json" ]]; then
        echo "[pre-commit] WARNING: ENABLE_TIDY=true but no compile_commands.json found." >&2
        echo "             Generate one with CMake: -DCMAKE_EXPORT_COMPILE_COMMANDS=ON"   >&2
        echo "             Skipping clang-tidy."                                           >&2
    else
        for f in "${STAGED_FILES[@]}"; do
            abs="${REPO_ROOT}/${f}"
            [[ -f "${abs}" ]] || continue
            # Only run tidy on .cpp / .cxx / .cc / .c (not headers)
            if echo "${f}" | grep -qE '\.(cpp|cxx|cc|c)$'; then
                tidy_out="$(
                    "${CLANG_TIDY_BIN}" \
                        -p "${REPO_ROOT}" \
                        --quiet \
                        "${abs}" 2>&1 || true
                )"
                if echo "${tidy_out}" | grep -qE 'warning:|error:'; then
                    TIDY_FAILURES+=("${f}")
                    if [[ "${VERBOSE}" == "true" ]]; then
                        echo "${tidy_out}"
                    fi
                fi
            fi
        done
    fi
fi

# ---------------------------------------------------------------------------
# 6.  Report and gate the commit
# ---------------------------------------------------------------------------
FAILED=false

if [[ ${#FORMAT_FAILURES[@]} -gt 0 ]]; then
    FAILED=true
    echo ""
    echo "╔══════════════════════════════════════════════════════════════════╗"
    echo "║  clang-format: LLVM style violations found — commit REJECTED    ║"
    echo "╚══════════════════════════════════════════════════════════════════╝"
    for f in "${FORMAT_FAILURES[@]}"; do
        echo "    ✗  ${f}"
    done
    echo ""
    echo "  Fix options:"
    echo "    Auto-fix staged files:  ${SUBMODULE_ROOT}/scripts/fix-format.sh"
    echo "    Manual inspection:      clang-format --style=file -i <file>"
    echo ""
fi

if [[ ${#TIDY_FAILURES[@]} -gt 0 ]]; then
    FAILED=true
    echo ""
    echo "╔══════════════════════════════════════════════════════════════════╗"
    echo "║  clang-tidy: diagnostic violations found — commit REJECTED      ║"
    echo "╚══════════════════════════════════════════════════════════════════╝"
    for f in "${TIDY_FAILURES[@]}"; do
        echo "    ✗  ${f}"
    done
    echo ""
fi

if [[ "${FAILED}" == "true" ]]; then
    echo "  To bypass (use sparingly):  git commit --no-verify"
    echo ""
    exit 1
fi

echo "[pre-commit] All style checks passed ✓"
exit 0
