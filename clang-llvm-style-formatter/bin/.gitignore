# Compiled clang-format binaries — generated by build-clang-format.sh
# These are platform-specific and produced on the developer's machine.
# They are intentionally NOT committed to the repository.
windows/clang-format.exe
linux/clang-format
macos/clang-format

# Keep the directory structure for git
!windows/.gitkeep
!linux/.gitkeep
!macos/.gitkeep
